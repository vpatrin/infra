{
  "uid": "postgres",
  "title": "PostgreSQL",
  "description": "Connections, performance, and storage for shared-postgres",
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": {
    "from": "now-30d",
    "to": "now"
  },
  "tags": ["postgresql", "database"],
  "links": [
    { "title": "Platform Health", "url": "/d/platform-health", "type": "link", "icon": "dashboard" },
    { "title": "Coupette", "url": "/d/coupette", "type": "link", "icon": "apps" },
    { "title": "Logs", "url": "/d/logs", "type": "link", "icon": "document-info" }
  ],
  "panels": [
    {
      "type": "row",
      "title": "Health",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "id": 1
    },
    {
      "type": "stat",
      "title": "PostgreSQL",
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 1 },
      "id": 40,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "pg_up", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red" },
                "1": { "text": "UP", "color": "green" }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "type": "stat",
      "title": "Connections",
      "gridPos": { "h": 5, "w": 8, "x": 8, "y": 1 },
      "id": 2,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(pg_stat_activity_count)", "legendFormat": "Active", "refId": "A" },
        { "expr": "pg_settings_max_connections", "legendFormat": "Max", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 90 }
            ]
          },
          "max": 100,
          "unit": "none"
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value_and_name",
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" }
      }
    },
    {
      "type": "gauge",
      "title": "Cache Hit Ratio",
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 1 },
      "id": 12,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(pg_stat_database_blks_hit{datname!~\"template.*|postgres\"}[5m])) / (sum(rate(pg_stat_database_blks_hit{datname!~\"template.*|postgres\"}[5m])) + sum(rate(pg_stat_database_blks_read{datname!~\"template.*|postgres\"}[5m])))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.95 },
              { "color": "green", "value": 0.99 }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "options": {
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "type": "stat",
      "title": "Deadlocks",
      "description": "Deadlocks in the last hour. Should always be 0.",
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 6 },
      "id": 50,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(pg_stat_database_deadlocks{datname!~\"template.*|postgres\"}[1h]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "type": "stat",
      "title": "Longest Tx",
      "description": "Longest running transaction in seconds. Red if stuck > 60s.",
      "gridPos": { "h": 5, "w": 8, "x": 8, "y": 6 },
      "id": 51,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "max(pg_stat_activity_max_tx_duration)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "red", "value": 60 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "type": "stat",
      "title": "Database Sizes",
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 6 },
      "id": 31,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "pg_database_size_bytes{datname!~\"template.*|postgres\"}",
          "legendFormat": "{{datname}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1073741824 },
              { "color": "red", "value": 5368709120 }
            ]
          },
          "unit": "bytes"
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value_and_name",
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" }
      }
    },
    {
      "type": "row",
      "title": "Activity",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 12 },
      "collapsed": false,
      "id": 10
    },
    {
      "type": "timeseries",
      "title": "Transactions per second",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "id": 11,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 0,
            "lineWidth": 2,
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "ops"
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "sum by (datname) (rate(pg_stat_database_xact_commit{datname!~\"template.*|postgres\"}[5m]) + rate(pg_stat_database_xact_rollback{datname!~\"template.*|postgres\"}[5m]))",
          "legendFormat": "{{datname}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Connections by state",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "id": 4,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 0,
            "lineWidth": 2,
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "none"
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "sum by (state) (pg_stat_activity_count{state!=\"\"})",
          "legendFormat": "{{state}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Database size over time",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 21 },
      "id": 32,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 0,
            "lineWidth": 2,
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "bytes"
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "pg_database_size_bytes{datname!~\"template.*|postgres\"}",
          "legendFormat": "{{datname}}",
          "refId": "A"
        }
      ]
    }
  ]
}
