      },
      "options": {
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "type": "row",
      "title": "Coupette Backend",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 67
      },
      "collapsed": false,
      "id": 50
    },
    {
      "type": "stat",
      "title": "Backend Up",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 68
      },
      "id": 51,
