{
  "uid": "logs",
  "title": "Logs",
  "description": "Infrastructure, application, and scheduled job logs via Loki",
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "tags": ["logs"],
  "links": [
    { "title": "Platform Health", "url": "/d/platform-health", "type": "link", "icon": "dashboard" },
    { "title": "PostgreSQL", "url": "/d/postgres", "type": "link", "icon": "database" },
    { "title": "Coupette", "url": "/d/coupette", "type": "link", "icon": "apps" }
  ],
  "templating": {
    "list": [
      {
        "name": "search",
        "label": "Search all logs",
        "type": "textbox",
        "current": { "text": "", "value": "" }
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Infrastructure",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "id": 1
    },
    {
      "type": "logs",
      "title": "Infra Logs",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 1 },
      "id": 2,
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{container=~\"caddy|shared-postgres|grafana|alloy|loki|prometheus|uptime-kuma|cadvisor\"} |~ \"(?i)$search\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "type": "row",
      "title": "Application",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "collapsed": false,
      "id": 3
    },
    {
      "type": "logs",
      "title": "App Logs",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 14 },
      "id": 4,
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{container=~\"coupette-backend|coupette-bot.*\"} |~ \"(?i)$search\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "type": "row",
      "title": "Scheduled Jobs",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 },
      "collapsed": true,
      "id": 5,
      "panels": [
        {
          "type": "logs",
          "title": "Job Logs",
          "description": "Backups, alerts, scraper, availability (via journald)",
          "gridPos": { "h": 12, "w": 24, "x": 0, "y": 27 },
          "id": 6,
          "datasource": { "type": "loki", "uid": "loki" },
          "targets": [
            {
              "expr": "{job=\"systemd-journal\"}",
              "refId": "A"
            }
          ],
          "options": {
            "showTime": true,
            "showLabels": true,
            "showCommonLabels": false,
            "wrapLogMessage": true,
            "prettifyLogMessage": false,
            "enableLogDetails": true,
            "sortOrder": "Descending",
            "dedupStrategy": "none"
          }
        }
      ]
    }
  ]
}
