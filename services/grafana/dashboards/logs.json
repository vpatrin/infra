{
  "uid": "logs",
  "title": "Logs",
  "description": "Application, infrastructure, and scheduled job logs via Loki",
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "tags": ["logs"],
  "links": [
    { "title": "Platform Health", "url": "/d/platform-health", "type": "link", "icon": "dashboard" },
    { "title": "PostgreSQL", "url": "/d/postgres", "type": "link", "icon": "database" },
    { "title": "Coupette", "url": "/d/coupette", "type": "link", "icon": "apps" }
  ],
  "templating": {
    "list": [
      {
        "name": "app",
        "label": "App",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": "label_values({container=~\"coupette-.*\"}, container)",
        "current": { "text": "All", "value": "$__all" },
        "includeAll": true,
        "allValue": "coupette-.*",
        "refresh": 2,
        "sort": 1
      },
      {
        "name": "infra",
        "label": "Infra",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": "label_values({container!~\"coupette-.*\"}, container)",
        "current": { "text": "All", "value": "$__all" },
        "includeAll": true,
        "allValue": "caddy|shared-postgres|grafana|alloy|loki|prometheus|uptime-kuma|cadvisor|umami",
        "refresh": 2,
        "sort": 1
      },
      {
        "name": "unit",
        "label": "Job",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": "label_values(unit)",
        "current": { "text": "All", "value": "$__all" },
        "includeAll": true,
        "allValue": ".+",
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Application",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "id": 3
    },
    {
      "type": "logs",
      "title": "App Logs",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 1 },
      "id": 4,
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{container=~\"$app\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "type": "row",
      "title": "Infrastructure",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "collapsed": false,
      "id": 1
    },
    {
      "type": "logs",
      "title": "Infra Logs",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 14 },
      "id": 2,
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{container=~\"$infra\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "type": "row",
      "title": "Scheduled Jobs",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 },
      "collapsed": true,
      "id": 5,
      "panels": [
        {
          "type": "logs",
          "title": "Job Logs",
          "description": "Backups, alerts, scraper, availability (via journald)",
          "gridPos": { "h": 12, "w": 24, "x": 0, "y": 27 },
          "id": 6,
          "datasource": { "type": "loki", "uid": "loki" },
          "targets": [
            {
              "expr": "{unit=~\"$unit\"}",
              "refId": "A"
            }
          ],
          "options": {
            "showTime": true,
            "showLabels": true,
            "showCommonLabels": false,
            "wrapLogMessage": true,
            "prettifyLogMessage": false,
            "enableLogDetails": true,
            "sortOrder": "Descending",
            "dedupStrategy": "none"
          }
        }
      ]
    }
  ]
}
