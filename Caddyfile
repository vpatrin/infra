victorpatrin.dev {
    root * /srv/homepage
    file_server
}

s.victorpatrin.dev {
    reverse_proxy url-shortener-api:8000
}

analytics.victorpatrin.dev {
    reverse_proxy umami:3000
}

status.victorpatrin.dev {
    reverse_proxy uptime-kuma:3001
}

wine.victorpatrin.dev {
    handle /api/* {
        reverse_proxy saq-backend:8001
    }
    handle {
        root * /srv/wine
        file_server
        try_files {path} /index.html
    }
}
