# Managed by Ansible — do not edit manually.
# Minimal audit rules for CIS 4.1.x / ANSSI-BP-028 R73.

# Identity file changes
-w /etc/passwd -p wa -k identity
-w /etc/group -p wa -k identity
-w /etc/shadow -p wa -k identity
-w /etc/gshadow -p wa -k identity

# Sudoers changes
-w /etc/sudoers -p wa -k sudoers
-w /etc/sudoers.d/ -p wa -k sudoers

# Login/session tracking
-w /var/run/utmp -p wa -k session
-w /var/log/wtmp -p wa -k session
-w /var/log/btmp -p wa -k session

# Privileged command execution
-a always,exit -F path=/usr/bin/sudo -F perm=x -F auid>=1000 -F auid!=4294967295 -k privileged
-a always,exit -F path=/usr/bin/su -F perm=x -F auid>=1000 -F auid!=4294967295 -k privileged

# Docker socket access
-w /var/run/docker.sock -p wa -k docker

# SSH config changes
-w /etc/ssh/sshd_config -p wa -k sshd
-w /etc/ssh/sshd_config.d/ -p wa -k sshd

# Make audit config immutable (CIS 4.1.18).
# After this, audit rules cannot be changed without a reboot.
# Re-running Ansible will deploy new rules to disk, but they
# won't take effect until the next reboot.
-e 2
