# Managed by Ansible — do not edit manually.
# Crypto hardening for OpenSSH 10.0+ (Debian 13).

# Post-quantum KEX first, then curve25519
KexAlgorithms mlkem768x25519-sha256,sntrup761x25519-sha512@openssh.com,curve25519-sha256,curve25519-sha256@libssh.org

# AEAD ciphers only (no AES-CTR)
Ciphers chacha20-poly1305@openssh.com,aes256-gcm@openssh.com,aes128-gcm@openssh.com

# ETM MACs only
MACs hmac-sha2-512-etm@openssh.com,hmac-sha2-256-etm@openssh.com

# Modern host key algorithms
HostKeyAlgorithms ssh-ed25519,rsa-sha2-512,rsa-sha2-256

# Session limits
MaxAuthTries 3
MaxSessions 2
LoginGraceTime 30
ClientAliveInterval 300
ClientAliveCountMax 2
TCPKeepAlive no

# Restrict SSH to admin + deploy users only
AllowUsers {{ admin_user }} {{ deploy_user }}

# Verbose logging for forensics (ANSSI-BP-028 R67)
LogLevel VERBOSE

# Disable features we don't use
X11Forwarding no
AllowAgentForwarding no
PermitTunnel no
GatewayPorts no
